<%= semantic_form_for [:admin, @gallery], builder: ActiveAdmin::FormBuilder do |f| %>
  <%= f.inputs do %>
    <%= f.input :title %>
    <%= f.input :description %>
    <%= f.input :page %>
    <%= f.input :feature %>
    <%= f.input :row_order %>
  <% end %>
  <%= f.inputs "Images" do %>
    <% f.has_many :images, heading: false, allow_destroy: true, new_record: true do |img| %>
      <% img.input :image, as: :file, hint: img.object&.image&.attached? ? img.object.image.filename : nil %>
      <% img.input :row_order %>
    <% end %>
  <% end %>
  <%= f.actions %>
<% end %>
